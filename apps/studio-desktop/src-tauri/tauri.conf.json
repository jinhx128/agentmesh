{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentMesh",
  "version": "0.1.11",
  "identifier": "dev.agentmesh.studio",
  "build": {
    "frontendDist": "../shell"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentMesh",
        "width": 1280,
        "height": 900,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": ["../../../dist-node/apps/studio-desktop/sidecar/agentmesh-studio-sidecar"],
    "resources": {
      "../../../dist-node/apps/studio-desktop/sidecar": "dist-node/apps/studio-desktop/sidecar",
      "../../../dist-node/apps/studio-desktop/src": "dist-node/apps/studio-desktop/src",
      "../../../dist-node/apps/studio-web/frontend": "dist-node/apps/studio-web/frontend",
      "../../../dist-node/packages/app-server": "dist-node/packages/app-server",
      "../../../dist-node/packages/cli": "dist-node/packages/cli",
      "../../../dist-node/packages/core": "dist-node/packages/core",
      "../../../dist-node/packages/runtime": "dist-node/packages/runtime",
      "../../../dist-node/packages/sdk": "dist-node/packages/sdk",
      "../../../dist-node/packages/skills": "dist-node/packages/skills",
      "../../../dist-node/apps/studio-desktop/runtime-node_modules": "dist-node/node_modules",
      "../../../package.json": "package.json",
      "../../../packages/skills/agentmesh-skill": "packages/skills/agentmesh-skill"
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/jinhx128/agentmesh/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCRTRGRjg2MDc2NEE4QTUKUldTbHFHUUhodi9rUzJYNVVUMTVwM0xuQ0ZpSUdqZ3MyNGJlNzlPUDJsYlk2QWpNbW1IVTJMMG8K"
    }
  }
}
